# Required: Supabase (free tier works)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Required: Anthropic (for cloud model tiers)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: OpenAI (for embeddings only)
OPENAI_API_KEY=sk-your-key-here

# Optional: GitHub (for github_search tool, higher rate limits)
GITHUB_TOKEN=ghp_your-token-here

# Local model config
OLLAMA_MODEL=qwen3:32b
OLLAMA_MODEL_LIGHT=qwen3:8b

# Agent settings
MAX_ITERATIONS=10
DAILY_BUDGET_USD=5.00

# Docker (auto-detected on most systems)
# DOCKER_HOST=unix:///var/run/docker.sock

# Code execution: allow subprocess fallback when Docker is unavailable (default: false)
# ALLOW_SUBPROCESS=false

# MCP Server (only needed for Railway deployment)
# MCP_BASE_URL=https://your-app.railway.app

# Notifications
NOTIFICATION_METHOD=macos
NOTIFICATION_LOG_PATH=~/.cairn/notifications.log
